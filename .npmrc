# Enforce the Node floor from package.json `engines`.
#
# NOTE: this does NOT make `npm install` fail fast in this repo. npm resolves
# the entire dependency tree before it checks anything, and because
# node_modules/ is a pnpm store it spends minutes crawling ~965 packages and
# then reports an ERESOLVE about `knip` — a devDependency of
# @eslint-community/eslint-utils that this project has no relationship with.
#
# There is nothing to fix in the dependency graph. Use pnpm:
#   pnpm install        pnpm add <pkg>        pnpm dlx <pkg>
engine-strict=true
