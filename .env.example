# itrix-dashboard — Surface 2 v5.0 environment
#
# Copy to .env.local and adjust. Every NEXT_PUBLIC_* value is INLINED AT BUILD
# TIME by Next.js: a flag set only in the runtime environment has no effect.
# Verify these during `pnpm build`, not after it.

# ── Backend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=iTrix Operations

# ── Mock mode ────────────────────────────────────────────────────────────────
# SECURITY: mock mode grants an unauthenticated ADMIN session and serves
# fixtures instead of calling Django. It is opt-in BY EXACT VALUE ("true" and
# nothing else) AND force-disabled in production builds. Leave it unset for any
# deployment that talks to a real backend.
NEXT_PUBLIC_USE_MOCKS=false

# ── Feature flags (Surface 2 v5.0 §10) ───────────────────────────────────────
# Each phase is independently shippable behind its flags, so the live CRM keeps
# running throughout. With all of these off, the dashboard is the shipped v3.0
# CRM plus the unflagged security and token corrections.
NEXT_PUBLIC_ENABLE_THREAD_OVERSIGHT=false     # Phase 1 — live conversation oversight
NEXT_PUBLIC_ENABLE_CUSTOMER_SUCCESS=false     # Phase 2 — customers, support, success reviews
NEXT_PUBLIC_ENABLE_ATTACHMENT_REVIEW=false    # Phase 2 — attachment queue, scan + quarantine
NEXT_PUBLIC_ENABLE_COVERAGE_READING=false     # Phase 2 — coverage map + question-loop audit
NEXT_PUBLIC_ENABLE_CUSTOMER_FIRST_NBA=false   # Phase 3 — NBA suppression + logged overrides
NEXT_PUBLIC_ENABLE_STREAMING_APPROVAL=false   # Phase 3 — blocking approvals + guard-hit console

# ── Server-only ──────────────────────────────────────────────────────────────
# Not NEXT_PUBLIC_: never inlined into the client bundle.
DJANGO_API_URL=http://localhost:8000/api/v1
